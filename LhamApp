                stream=True
            )

            resposta_da_ia = ""
            tokens_saida = 0
            ultimo_update_ui = time.perf_counter()

            for chunk in stream_response:
                if 'message' in chunk and 'content' in chunk['message']:
                    resposta_da_ia += chunk['message']['content']
                    
                    agora = time.perf_counter()
                    if agora - ultimo_update_ui > 0.1:
                        resposta_placeholder.markdown(resposta_da_ia + " ▌")
