class TokenizerManager:
    """Gerenciador central de tokenizadores com mapeamento fluído de famílias de modelos."""
    
    # Repositórios de referência estáveis do Hugging Face para cada arquitetura utilizada
    REPOSITORIOS = {
        "qwen": "Qwen/Qwen2.5-Coder-3B-Instruct",
        "gemma": "google/gemma-2-9b-it",
        "phi": "microsoft/Phi-4-mini-instruct"
    }

    @staticmethod
    @st.cache_resource
    def carregar_tokenizer(repo_id):
        """Efetua a carga isolada e cacheada do arquivo de mapeamento vocabular."""
        if AutoTokenizer is not None:
            try:
                return AutoTokenizer.from_pretrained(repo_id)
            except Exception:
                return None
        return None

    @classmethod
    def obter_por_modelo(cls, nome_modelo):
        """Varre o identificador do modelo ativo e resolve o tokenizer compatível."""
        if not nome_modelo:
            return None
        
        modelo_lower = nome_modelo.lower()
        for chave, repo in cls.REPOSITORIOS.items():
            if chave in modelo_lower:
                return cls.carregar_tokenizer(repo)
        return None


def contar_tokens(texto, nome_modelo=None):
    """Conta os tokens reais adaptando-se dinamicamente à arquitetura de LLM ativa."""
    if not texto:
        return 0
        
    if nome_modelo is None and "modelo_ia_ativo" in st.session_state:
        nome_modelo = st.session_state.modelo_ia_ativo
        
    tokenizer = TokenizerManager.obter_por_modelo(nome_modelo)
    if tokenizer:
        try:
            return len(tokenizer.encode(texto))
        except Exception:
            pass
            
    return len(texto) // 4

def construir_prompt_sistema_completo(system_prompt_base, contexto_arquivo):
    """Encapsula a lógica de junção do System Prompt com os metadados dos arquivos injetados."""
    prompt_completo = system_prompt_base
    if contexto_arquivo:
        prompt_completo += "\n\n" + contexto_arquivo
    return prompt_completo

def calcular_tokens_historico(mensagens, nome_modelo=None):
    """Soma os tokens contidos unicamente no histórico linear de mensagens usando o modelo ativo."""
    return sum(contar_tokens(m["content"], nome_modelo) for m in mensagens)

def selecionar_contexto_por_tokens(mensagens, system_prompt_completo, max_tokens=ORCAMENTO_CONTEXTO_MAXIMO):
    """
    Varre o histórico de trás para frente e seleciona as mensagens mais recentes 
    que respeitam o teto do orçamento definido, garantindo margem estável para a resposta.
    """
    nome_modelo = st.session_state.get("modelo_ia_ativo")
    tokens_base = contar_tokens(system_prompt_completo, nome_modelo)
    tokens_acumulados = tokens_base
    contexto_selecionado = []
    
    for msg in reversed(mensagens):
        tokens_msg = contar_tokens(msg["content"], nome_modelo)
        if tokens_acumulados + tokens_msg > max_tokens:
            registrar_log(f"Janela Deslizante: Mensagens antigas cortadas para preservar limite de {max_tokens} tokens.")
            break
        contexto_selecionado.insert(0, msg)
        tokens_acumulados += tokens_msg
        
    return contexto_selecionado, tokens_acumulados

def obter_estatisticas_contexto(mensagens, system_prompt_base, contexto_arquivo, max_contexto=JANELA_CONTEXTO_PADRAO):
    """
    Calcula as métricas unificadas de consumo do histórico total e de simulação 
    do que seria enviado ao modelo na janela deslizante atual.
    """
    nome_modelo = st.session_state.get("modelo_ia_ativo")
    prompt_completo = construir_prompt_sistema_completo(system_prompt_base, contexto_arquivo)
    tokens_base = contar_tokens(prompt_completo, nome_modelo)
    tokens_hist = calcular_tokens_historico(mensagens, nome_modelo)
    
    _, tokens_enviados = selecionar_contexto_por_tokens(mensagens, prompt_completo, ORCAMENTO_CONTEXTO_MAXIMO)
    pct_uso = (tokens_enviados / max_contexto) if max_contexto > 0 else 0.0
    
    return {
        "tokens_historico_total": tokens_base + tokens_hist,
        "tokens_contexto_enviado": tokens_enviados,
        "percentual_contexto": min(pct_uso, 1.0),
        "janela_contexto": max_contexto
    }

def atualizar_metricas_contexto(mensagens, system_prompt_base, contexto_arquivo):
    """Varre a composição de inputs e sincroniza os dados calculados de contexto no Session State."""
    estatisticas = obter_estatisticas_contexto(mensagens, system_prompt_base, contexto_arquivo, JANELA_CONTEXTO_PADRAO)
    st.session_state.tokens_historico = estatisticas["tokens_historico_total"]
    st.session_state.tokens_contexto_enviado = estatisticas["tokens_contexto_enviado"]
    st.session_state.percentual_contexto = estatisticas["percentual_contexto"]
    st.session_state.janela_contexto = estatisticas["janela_contexto"]

def estimar_tokens_totais(mensagens, system_prompt):
    """Calcula o volume total de tokens acumulados no chat atual (Mantida para compatibilidade)."""
    nome_modelo = st.session_state.get("modelo_ia_ativo")
    texto_completo = system_prompt
    for m in mensagens:
        texto_completo += m["content"]
    return contar_tokens(texto_completo, nome_modelo)

