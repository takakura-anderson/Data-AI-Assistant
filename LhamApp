def processar_tabular(arquivo, extensao):
    if extensao == '.csv': df = pd.read_csv(arquivo)
    elif extensao == '.parquet': df = pd.read_parquet(arquivo)
    else: df = pd.read_excel(arquivo)
    
    buffer = io.StringIO()
    df.info(buf=buffer)
    info_str = buffer.getvalue()
    
    resumo = f"- **Linhas:** {df.shape[0]} | **Colunas:** {df.shape[1]}\n"
    resumo += f"- **Nulos totais:** {df.isnull().sum().sum()} | **Duplicados:** {df.duplicated().sum()}\n\n"
    resumo += f"**Info de Memória e Tipos:**\n{info_str}\n\n"
    resumo += f"**Estatísticas (Describe):**\n{df.describe().to_string()}\n\n"
    resumo += f"**Amostra (Primeiras linhas):**\n{df.head(3).to_string()}"
    return resumo

