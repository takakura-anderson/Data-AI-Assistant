                if chunk.get("done"):
                    tokens_saida = chunk.get("eval_count", 0)
                    tokens_reais_entrada_ollama = chunk.get("prompt_eval_count", 0)
                    if tokens_reais_entrada_ollama > 0:
                        tokens_reais_entrada = tokens_reais_entrada_ollama
                    if tokens_saida == 0:
                        tokens_saida = contar_tokens(resposta_da_ia, modelo_selecionado)

            t_inf = time.perf_counter() - t_inf_inicio

            resposta_placeholder.markdown(resposta_da_ia)

            t_pos_inicio = time.perf_counter()
            st.session_state.messages.append({"role": "assistant", "content": resposta_da_ia})
            t_pos = time.perf_counter() - t_pos_inicio

            tempo_total = time.perf_counter() - t_inicio
            velocidade = tokens_saida / t_inf if t_inf > 0 else 0

            st.session_state.ultimo_modelo = modelo_selecionado if modelo_selecionado else "Desconhecido"
            st.session_state.ultima_velocidade = velocidade
            st.session_state.ultimo_tempo_total = tempo_total
            
            atualizar_metricas_contexto(st.session_state.messages, system_prompt_atual, st.session_state.contexto_arquivo)

            status_progresso.update(label=f"✅ Resposta concluída em {tempo_total:.2f}s", state="complete")
            
            col1, col2, col3, col4, col5 = metricas_placeholder.columns(5)
            col1.metric("Tempo Total", f"{tempo_total:.2f} s")
            col2.metric("Velocidade", f"{velocidade:.1f} t/s")
            col3.metric("Tokens Entrada", f"{tokens_reais_entrada}")
            col4.metric("Tokens Saída", f"{tokens_saida}")
            col5.metric("Modelo", modelo_selecionado)

            log_desempenho = (
                f"Desempenho da Inferência:\n"
                f" - Preparação: {t_prep:.2f} s\n"
                f" - Inferência Ollama: {t_inf:.2f} s\n"
                f" - Pós-processamento: {t_pos:.2f} s\n"
                f" - Tempo total: {tempo_total:.2f} s"
            )
            registrar_log(log_desempenho)
            
            st.rerun()

        except Exception as e:
            registrar_log(f"ERRO: Falha na comunicação. {str(e)}")
            status_progresso.update(label="❌ Erro na comunicação com o modelo", state="error")
            st.error("Falha ao conectar ao Ollama. Certifique-se de que o serviço está rodando em segundo plano.")
