def processar_tabular(arquivo, extensao):
    if extensao == '.csv': df = pd.read_csv(arquivo)
    elif extensao == '.parquet': df = pd.read_parquet(arquivo)
    else: df = pd.read_excel(arquivo)
    
    buffer = io.StringIO()
    df.info(buf=buffer)
    info_str = buffer.getvalue()
    
    resumo = f"- **Linhas:** {df.shape[0]} | **Colunas:** {df.shape[1]}\n"
    resumo += f"- **Nulos totais:** {df.isnull().sum().sum()} | **Duplicados:** {df.duplicated().sum()}\n\n"
    resumo += f"**Info de Memória e Tipos:**\n{info_str}\n\n"
    resumo += f"**Estatísticas (Describe):**\n{df.describe().to_string()}\n\n"
    resumo += f"**Amostra (Primeiras linhas):**\n{df.head(3).to_string()}"
    return resumo

def processar_pdf(arquivo, extensao):
    if not PdfReader: return "Erro: Biblioteca 'pypdf' não instalada."
    reader = PdfReader(arquivo)
    num_paginas = len(reader.pages)
    texto = ""
    for i in range(min(5, num_paginas)):
        texto += reader.pages[i].extract_text() + "\n"
    resumo = f"- **Total de Páginas:** {num_paginas}\n\n"
    resumo += f"**Amostra do Texto Inicial:**\n{texto[:2500]}..."
    return resumo

def processar_docx(arquivo, extensao):
    if not docx: return "Erro: Biblioteca 'python-docx' não instalada."
    doc = docx.Document(arquivo)
    texto = "\n".join([p.text for p in doc.paragraphs if p.text.strip() != ""])
    resumo = f"- **Total de Parágrafos válidos:** {len(doc.paragraphs)}\n\n"
    resumo += f"**Amostra do Texto Inicial:**\n{texto[:2500]}..."
    return resumo

def processar_texto(arquivo, extensao):
    conteudo = arquivo.read().decode('utf-8', errors='ignore')
    linhas = len(conteudo.splitlines())
    palavras = len(conteudo.split())
    resumo = f"- **Total de Linhas:** {linhas} | **Total de Palavras:** {palavras}\n\n"
    resumo += f"**Amostra do Texto:**\n{conteudo[:2500]}..."
    return resumo

def processar_python(arquivo, extensao):
    conteudo = arquivo.read().decode('utf-8', errors='ignore')
    linhas = len(conteudo.splitlines())
    resumo = f"- **Total de Linhas:** {linhas}\n"
    try:
        tree = ast.parse(conteudo)
        classes = [n.name for n in ast.walk(tree) if isinstance(n, ast.ClassDef)]
        funcoes = [n.name for n in ast.walk(tree) if isinstance(n, ast.FunctionDef)]
        imports = [n.names[0].name for n in ast.walk(tree) if isinstance(n, (ast.Import, ast.ImportFrom))]
        
        resumo += f"- **Imports detectados:** {', '.join(imports)}\n"
        resumo += f"- **Classes detectadas:** {', '.join(classes) if classes else 'Nenhuma'}\n"
        resumo += f"- **Funções detectadas:** {', '.join(funcoes) if funcoes else 'Nenhuma'}\n\n"
    except SyntaxError:
        resumo += "*(Nota: O arquivo possui erros de sintaxe ou é um fragmento de código).*\n\n"
    resumo += f"**Amostra do Código:**\n{conteudo[:2000]}..."
    return resumo

def processar_sql(arquivo, extensao):
    conteudo = arquivo.read().decode('utf-8', errors='ignore')
    tabelas = set(re.findall(r'(?:FROM|JOIN)\s+([a-zA-Z0-9_.]+)', conteudo, re.IGNORECASE))
    ctes = len(re.findall(r'\bWITH\b', conteudo, re.IGNORECASE))
    resumo = f"- **Tabelas Referenciadas:** {', '.join(tabelas) if tabelas else 'Não detectadas/Uso de alias'}\n"
    resumo += f"- **CTEs (WITH) detectadas:** {ctes}\n\n"
    resumo += f"**Amostra da Consulta:**\n{conteudo[:2000]}..."
    return resumo

def processar_estruturado(arquivo, extensao):
    conteudo = arquivo.read().decode('utf-8', errors='ignore')
    resumo = ""
    try:
        if extensao == '.json':
            dados = json.loads(conteudo)
            chaves = list(dados.keys()) if isinstance(dados, dict) else "Estrutura de Lista/Array"
            resumo = f"- **Formato:** JSON | **Chaves Principais:** {chaves}\n\n"
        elif extensao in ['.yaml', '.yml']:
            dados = yaml.safe_load(conteudo) if yaml else None
            chaves = list(dados.keys()) if isinstance(dados, dict) else "Estrutura Base"
            resumo = f"- **Formato:** YAML | **Chaves Principais:** {chaves}\n\n"
        elif extensao == '.xml':
            resumo = f"- **Formato:** XML\n\n"
    except Exception as e:
        resumo = f"- *(Aviso: Não foi possível realizar o parse estrutural perfeito: {e})*\n\n"
        
    resumo += f"**Amostra do Conteúdo:**\n{conteudo[:2000]}..."
    return resumo

PROCESSADORES_ARQUIVO = {
    '.csv': processar_tabular, '.xlsx': processar_tabular, '.xls': processar_tabular, '.parquet': processar_tabular,
    '.pdf': processar_pdf,
    '.docx': processar_docx,
    '.txt': processar_texto, '.md': processar_texto,
    '.py': processar_python,
    '.sql': processar_sql,
    '.json': processar_estruturado, '.xml': processar_estruturado, '.yaml': processar_estruturado, '.yml': processar_estruturado
}

